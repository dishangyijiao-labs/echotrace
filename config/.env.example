# Django Configuration
SECRET_KEY=your-secret-key-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-change-me-in-production
JWT_ACCESS_TOKEN_TTL=720  # 12 hours (minutes)
JWT_REFRESH_TOKEN_TTL=10080  # 7 days (minutes)

# Database
DATABASE_PATH=db.sqlite3

# Transcription Engine
WHISPER_MODEL=small  # tiny/base/small/medium/large
WHISPER_DEVICE=auto  # auto/cpu/cuda
WHISPER_LANGUAGE=auto  # zh/en/auto

# Worker Configuration
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL=5  # seconds

# NAS Configuration (Optional)
NAS_ADDRESS=//nas.local/videos
NAS_USERNAME=user
NAS_PASSWORD=your-password
NAS_MOUNT_POINT=/mnt/nas

# Scheduler
SCHEDULER_ENABLED=True
SCHEDULER_CRON=0 23 * * *  # Daily at 23:00

# Logging
LOG_LEVEL=INFO

# File Size Limits
MAX_FILE_SIZE=2147483648  # 2GB in bytes
TRANSCRIPTION_TIMEOUT=3600  # 1 hour in seconds
