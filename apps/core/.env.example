# EchoTrace Environment Variables
# Copy this file to .env and fill in your API keys.
# All keys are optional — only configure the providers you plan to use.

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# Doubao (Volcengine)
# DOUBAO_API_KEY=...

# Local LLM (Ollama) — no API key needed, runs on localhost:11434 by default
