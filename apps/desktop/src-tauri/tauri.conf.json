{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoTrace",
  "version": "0.1.0",
  "identifier": "com.echotrace.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "width": 1280,
        "height": 900
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* ipc: asset:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../core/app.py": "core/app.py",
      "../../core/worker.py": "core/worker.py",
      "../../core/download_manager.py": "core/download_manager.py",
      "../../core/errors.py": "core/errors.py",
      "../../core/llm_service.py": "core/llm_service.py",
      "../../core/requirements.txt": "core/requirements.txt",
      "../../core/db": "core/db",
      "../../core/pipeline": "core/pipeline",
      "../../core/rag": "core/rag"
    }
  }
}
