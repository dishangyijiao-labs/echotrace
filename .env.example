# EchoTrace Environment Configuration
# Copy this file to .env and update the values

# ============================================
# Core API Configuration
# ============================================

# Port for the Core API server (default: 8787)
# CORE_PORT=8787

# Host for the Core API server (default: 127.0.0.1)
# Use 0.0.0.0 to allow external access (not recommended for production)
# CORE_HOST=127.0.0.1

# ============================================
# Database Configuration
# ============================================

# Path to the SQLite database file (default: data/app.db)
# DB_PATH=data/app.db

# ============================================
# Transcription Configuration
# ============================================

# Default Whisper model size (tiny, base, small, medium, large-v2, large-v3)
# Default: small (good balance of speed and accuracy)
# DEFAULT_MODEL=small

# Default device for transcription (cpu, cuda, auto)
# Default: cpu
# DEFAULT_DEVICE=cpu

# ============================================
# RAG / Semantic Search (Optional)
# ============================================

# Enable semantic search (requires additional dependencies)
# Set to true to enable vector-based semantic search
# ECHOTRACE_SEMANTIC_SEARCH=false

# Embedding provider for semantic search (local, openai)
# EMBEDDING_PROVIDER=local

# ============================================
# MCP / AI Providers (Optional)
# ============================================

# Path to MCP providers configuration file
# MCP_PROVIDERS_PATH=providers.json

# ============================================
# Python Environment
# ============================================

# Path to Python 3.12 executable (optional, for packaged apps)
# ECHOTRACE_PYTHON=python3.12

# Core directory path (optional, for packaged apps)
# ECHOTRACE_CORE_DIR=../core
